FROM golang:1.25-alpine AS builder
WORKDIR /app

# Copy dependency files first for better layer caching.
COPY go.mod go.sum ./
COPY go.work* ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -o /bin/{{.Name}} ./cmd/...

FROM alpine:3.19
RUN apk add --no-cache ca-certificates
COPY --from=builder /bin/{{.Name}} /bin/{{.Name}}
ENTRYPOINT ["/bin/{{.Name}}"]
