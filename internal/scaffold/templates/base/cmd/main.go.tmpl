package main

import (
	"context"
	"log/slog"
	"os"

	"{{.Module}}/internal/adapters/handlers/itemhandler"
	"{{.Module}}/internal/app"

	"github.com/ALexfonSchneider/goplatform/pkg/platform"
	"github.com/ALexfonSchneider/goplatform/pkg/observe"
	"github.com/ALexfonSchneider/goplatform/pkg/server"
	"github.com/ALexfonSchneider/goplatform/pkg/config"
	{{- if .Postgres}}
	"{{.Module}}/internal/adapters/postgresrepo"
	"github.com/ALexfonSchneider/goplatform/pkg/postgres"
	{{- end}}
	{{- if .Kafka}}
	"{{.Module}}/internal/adapters/kafkaconsumer"
	"github.com/ALexfonSchneider/goplatform/pkg/broker/kafka"
	{{- end}}
	{{- if .NATS}}
	"{{.Module}}/internal/adapters/natsconsumer"
	natsbr "github.com/ALexfonSchneider/goplatform/pkg/broker/nats"
	{{- end}}
	{{- if .Redis}}
	"github.com/ALexfonSchneider/goplatform/pkg/redis"
	{{- end}}
	{{- if .Temporal}}
	"{{.Module}}/internal/adapters/temporalworker"
	"github.com/ALexfonSchneider/goplatform/pkg/workflow"
	{{- end}}
)

func main() {
	baseHandler := slog.NewJSONHandler(os.Stdout, nil)

	// Load config from per-component YAML files.
	loader, err := config.NewLoader(
		config.WithFiles(
			"config/config.yaml",
			{{- if .Postgres}}
			"config/config.postgres.yaml",
			{{- end}}
			{{- if .Kafka}}
			"config/config.kafka.yaml",
			{{- end}}
			{{- if .NATS}}
			"config/config.nats.yaml",
			{{- end}}
			{{- if .Redis}}
			"config/config.redis.yaml",
			{{- end}}
			{{- if .Temporal}}
			"config/config.temporal.yaml",
			{{- end}}
			{{- if .Connect}}
			"config/config.connect.yaml",
			{{- end}}
		),
		config.WithEnvPrefix("{{.Name | snake | upper}}"),
	)
	if err != nil {
		slog.Error("failed to create config loader", "error", err)
		os.Exit(1)
	}

	var cfg Config
	if err := loader.Load(&cfg); err != nil {
		slog.Error("failed to load config", "error", err)
		os.Exit(1)
	}

	// Observability: traces + metrics + log export.
	obs, err := observe.New(
		observe.WithServiceName(cfg.Observe.ServiceName),
		observe.WithOTLPEndpoint(cfg.Observe.OTLPEndpoint),
		observe.WithBaseHandler(baseHandler),
	)
	if err != nil {
		slog.Error("failed to create observer", "error", err)
		os.Exit(1)
	}

	// Logger: stdout before Start(), stdout + OTel after Start().
	logger := obs.Logger()

	application := platform.New(
		platform.WithLogger(logger),
	)
	_ = application.Register("observe", obs)

	{{- if .Postgres}}

	// Secondary adapter: PostgreSQL.
	db, err := postgres.New(
		postgres.WithDSN(cfg.Postgres.DSN),
		postgres.WithTracerProvider(obs.TracerProvider()),
		postgres.WithLogger(logger),
	)
	if err != nil {
		logger.Error("failed to create postgres", "error", err)
		os.Exit(1)
	}
	_ = application.Register("postgres", db)
	repo := postgresrepo.New(db)
	_ = repo // TODO: pass to app.NewService
	{{- end}}

	{{- if .Redis}}

	// Secondary adapter: Redis.
	rdb, err := redis.New(
		redis.WithAddr(cfg.Redis.Addr),
		redis.WithLogger(logger),
	)
	if err != nil {
		logger.Error("failed to create redis", "error", err)
		os.Exit(1)
	}
	_ = application.Register("redis", rdb)
	{{- end}}

	// Application layer.
	svc := app.NewService(logger)

	{{- if .Kafka}}

	// Kafka producer.
	kafkaProducer, err := kafka.NewProducer(
		kafka.WithBrokers(cfg.Kafka.Brokers...),
		kafka.WithProducerTracerProvider(obs.TracerProvider()),
		kafka.WithProducerLogger(logger),
	)
	if err != nil {
		logger.Error("failed to create kafka producer", "error", err)
		os.Exit(1)
	}
	_ = application.Register("kafka-producer", kafkaProducer)

	// Kafka consumer.
	kafkaConsumer, err := kafka.NewConsumer(
		kafka.WithConsumerBrokers(cfg.Kafka.Brokers...),
		kafka.WithGroupID("{{.Name}}"),
		kafka.WithConsumerTracerProvider(obs.TracerProvider()),
		kafka.WithConsumerLogger(logger),
	)
	if err != nil {
		logger.Error("failed to create kafka consumer", "error", err)
		os.Exit(1)
	}
	_ = application.Register("kafka-consumer", kafkaConsumer)

	// Register Kafka message handler.
	kc := kafkaconsumer.New(svc, logger)
	if err := kafkaConsumer.Subscribe(context.Background(), "{{.Name}}.events", kc.Handle); err != nil {
		logger.Error("failed to subscribe to kafka topic", "error", err)
		os.Exit(1)
	}
	{{- end}}

	{{- if .NATS}}

	// NATS publisher.
	natsPublisher, err := natsbr.NewPublisher(
		natsbr.WithURL(cfg.NATS.URL),
		natsbr.WithPublisherTracerProvider(obs.TracerProvider()),
		natsbr.WithPublisherLogger(logger),
	)
	if err != nil {
		logger.Error("failed to create nats publisher", "error", err)
		os.Exit(1)
	}
	_ = application.Register("nats-publisher", natsPublisher)

	// NATS subscriber.
	natsSubscriber, err := natsbr.NewSubscriber(
		natsbr.WithSubscriberURL(cfg.NATS.URL),
		natsbr.WithQueueGroup("{{.Name}}"),
		natsbr.WithSubscriberTracerProvider(obs.TracerProvider()),
		natsbr.WithSubscriberLogger(logger),
	)
	if err != nil {
		logger.Error("failed to create nats subscriber", "error", err)
		os.Exit(1)
	}
	_ = application.Register("nats-subscriber", natsSubscriber)

	// Register NATS message handler.
	nc := natsconsumer.New(svc, logger)
	if err := natsSubscriber.Subscribe(context.Background(), "{{.Name}}.events", nc.Handle); err != nil {
		logger.Error("failed to subscribe to nats subject", "error", err)
		os.Exit(1)
	}
	{{- end}}

	{{- if .Temporal}}

	// Temporal workflow client.
	wfClient, err := workflow.NewClient(
		workflow.WithHostPort(cfg.Temporal.HostPort),
		workflow.WithNamespace(cfg.Temporal.Namespace),
		workflow.WithTracerProvider(obs.TracerProvider()),
		workflow.WithClientLogger(logger),
	)
	if err != nil {
		logger.Error("failed to create temporal client", "error", err)
		os.Exit(1)
	}
	_ = application.Register("temporal-client", wfClient)

	// Temporal worker adapter.
	wfWorker, err := temporalworker.Setup(wfClient, svc, cfg.Temporal.TaskQueue, logger)
	if err != nil {
		logger.Error("failed to create temporal worker", "error", err)
		os.Exit(1)
	}
	_ = application.Register("temporal-worker", wfWorker)
	{{- end}}

	// HTTP server.
	srv, err := server.New(
		server.WithAddr(cfg.Server.Addr),
		server.WithLogger(logger),
		server.WithHealthCheckers(application.HealthCheckers()),
	)
	if err != nil {
		logger.Error("failed to create server", "error", err)
		os.Exit(1)
	}

	// OTel middleware: traces + metrics for every HTTP request.
	srv.Use(observe.HTTPMiddleware(obs.TracerProvider(), obs.MeterProvider()))

	// Primary adapters: HTTP handlers mounted at composition root.
	items := itemhandler.New(svc)
	srv.Mount("/api/v1/items", items.Routes())

	_ = application.Register("server", srv)

	if err := application.Run(context.Background()); err != nil {
		logger.Error("application error", "error", err)
		os.Exit(1)
	}
}

// Config holds the application configuration.
type Config struct {
	Server struct {
		Addr string `koanf:"addr"`
	} `koanf:"server"`
	Observe struct {
		ServiceName  string `koanf:"service_name"`
		OTLPEndpoint string `koanf:"otlp_endpoint"`
	} `koanf:"observe"`
	{{- if .Postgres}}
	Postgres struct {
		DSN string `koanf:"dsn"`
	} `koanf:"postgres"`
	{{- end}}
	{{- if .Kafka}}
	Kafka struct {
		Brokers []string `koanf:"brokers"`
	} `koanf:"kafka"`
	{{- end}}
	{{- if .NATS}}
	NATS struct {
		URL string `koanf:"url"`
	} `koanf:"nats"`
	{{- end}}
	{{- if .Redis}}
	Redis struct {
		Addr string `koanf:"addr"`
	} `koanf:"redis"`
	{{- end}}
	{{- if .Temporal}}
	Temporal struct {
		HostPort  string `koanf:"host_port"`
		Namespace string `koanf:"namespace"`
		TaskQueue string `koanf:"task_queue"`
	} `koanf:"temporal"`
	{{- end}}
	{{- if .Connect}}
	Connect struct {
		Reflection bool `koanf:"reflection"`
	} `koanf:"connect"`
	{{- end}}
}
