package handler

import (
	"net/http"

	"github.com/go-chi/chi/v5"

	"{{.Module}}/internal/app"
)

// Handler is a primary adapter that handles incoming HTTP requests
// and delegates business logic to the application Service.
type Handler struct {
	svc *app.Service
}

// New creates a new Handler.
func New(svc *app.Service) *Handler {
	return &Handler{svc: svc}
}

// Routes returns a chi.Router with all handler routes.
// The caller (main.go) decides the mount path.
func (h *Handler) Routes() chi.Router {
	r := chi.NewRouter()
	r.Get("/health", h.health)
	return r
}

func (h *Handler) health(w http.ResponseWriter, _ *http.Request) {
	w.Header().Set("Content-Type", "application/json")
	w.WriteHeader(http.StatusOK)
	_, _ = w.Write([]byte(`{"status":"ok"}`))
}
